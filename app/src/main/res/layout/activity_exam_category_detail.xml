<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.example.teacherforboss.presentation.ui.exam.category.ExamCategoryDetailViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:context=".presentation.ui.exam.category.ExamCategoryDetailActivity">

        <androidx.appcompat.widget.Toolbar
            xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/toolbar"
            android:background="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            ></androidx.appcompat.widget.Toolbar>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabCategory"
                app:tabSelectedTextColor="@color/Primary01"
                app:tabTextColor="@color/Gray06"
                app:tabTextAppearance="@style/TextAppearance.TeacherForBoss.Label3"
                app:tabMode="scrollable"
                app:layout_constraintTop_toTopOf="@+id/toolbar"

                android:background="@color/white"
                app:tabIndicatorColor="@color/Primary01"
                android:layout_width="match_parent"
                android:layout_height="40dp">

            </com.google.android.material.tabs.TabLayout>



            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_detail_category"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                app:layout_constraintTop_toBottomOf="@id/tabCategory"
                android:scrollbars="horizontal"
                android:scrollbarFadeDuration="0"

                >

            </androidx.recyclerview.widget.RecyclerView>



        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/rv_detail_category"
            >

        </androidx.viewpager2.widget.ViewPager2>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>