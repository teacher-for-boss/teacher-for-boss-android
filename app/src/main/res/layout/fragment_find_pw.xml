<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="findPwviewModel"
            type="com.example.teacherforboss.presentation.ui.auth.findinfo.FindPwViewModel" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".presentation.ui.auth.findinfo.screens.findPwFragment">

        <LinearLayout
            android:id="@+id/linearlayout"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="가입한 이메일 주소를 입력해주세요"
                android:textColor="@color/black"
                android:textSize="18dp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="20dp">

            </View>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/emailBox"
                    android:padding="12dp"
                    android:background="@drawable/selector_login"
                    android:hint="이메일"
                    android:textColorHint="@color/gray_02"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                </EditText>

                <Button
                    android:id="@+id/phoneVerifyBtn"
                    android:layout_width="70dp"
                    android:layout_height="35dp"
                    android:text="인증하기"
                    android:background="@drawable/radius_purple_button"
                    android:textColor="@color/white"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="16dp"
                    android:layout_centerVertical="true" />

            </RelativeLayout>

            <TextView
                android:id="@+id/veryInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="해당 휴대폰으로 인증 번호가 발송되었습니다."
                android:textColor="@color/black"
                android:textSize="12dp"
                android:visibility="visible"
                android:layout_marginStart="5dp"
                android:layout_marginTop="5dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="20dp">

            </View>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RelativeLayout

                    android:layout_width="250dp"
                    android:layout_height="wrap_content"
                    android:paddingRight="10dp">

                    <EditText
                        android:id="@+id/emailCodeBox"
                        android:padding="12dp"
                        android:background="@drawable/selector_login"
                        android:hint="인증번호 입력"
                        android:textColorHint="@color/gray_02"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                    </EditText>

                    <TextView
                        android:id="@+id/timer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="03:00"
                        android:textSize="18dp"
                        android:textColor="#ff0000"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:visibility="visible" />


                </RelativeLayout>

                <Button
                    android:id="@+id/phoneConfirmBtn"
                    android:layout_width="70dp"
                    android:layout_height="35dp"
                    android:text="확인"
                    android:background="@drawable/radius_purple_button"
                    android:textColor="@color/white"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="20dp"
                    android:layout_centerVertical="true" />

            </RelativeLayout>

            <TextView
                android:id="@+id/checkVery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='@{findPwviewModel.isEmailVerified()?"인증되었습니다.":"인증번호가 올바르지 않습니다."}'
                android:textColor="@{findPwviewModel.isEmailVerified()?@color/sub_green:@color/sub_red}"
                android:textSize="12dp"
                android:visibility="invisible"
                android:layout_marginStart="5dp"
                android:layout_marginTop="5dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="20dp">

            </View>

            <Button
                android:background="@drawable/radius_purple_button"
                android:text="비밀번호 재설정"
                android:textColor="@color/white"
                android:id="@+id/findEmailBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            </Button>


        </LinearLayout>

    </LinearLayout>
</layout>