<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".signup.fragment.NamePhoneFragment">

    <data>
        <variable
            name="signupViewModel"
            type="com.example.teacherforboss.presentation.ui.auth.signup.SignupViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:background="@color/white"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            >

            <ProgressBar
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:background="@color/gray_02"
                android:progressTint="@color/main_purple_00"
                android:progress="55"
                android:max="100"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="14dp">

            </View>

            <LinearLayout
                android:id="@+id/linearlayout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="휴대폰 본인인증을 해주세요\n"
                    android:textColor="@color/black"
                    android:textSize="20dp"
                    android:textStyle="bold"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="55dp">

                </View>

                <EditText
                    android:id="@+id/nameBox"
                    android:padding="12dp"
                    android:background="@drawable/selector_login"
                    android:hint="이름"
                    android:textColorHint="@color/gray_02"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                </EditText>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="20dp">

                </View>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <EditText
                        android:id="@+id/phoneNumBox"
                        android:padding="12dp"
                        android:background="@drawable/selector_login"
                        android:hint="휴대폰 번호 ('-' 제외)"
                        android:textColorHint="@color/gray_02"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                    </EditText>

                    <Button
                        android:id="@+id/phoneVerifyBtn"
                        android:layout_width="70dp"
                        android:layout_height="35dp"
                        android:text="인증하기"
                        android:background="@drawable/radius_purple_button"
                        android:textColor="@color/white"
                        android:layout_alignParentEnd="true"
                        android:layout_marginEnd="20dp"
                        android:layout_centerVertical="true"/>

                </RelativeLayout>

                <TextView
                    android:id="@+id/veryInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="해당 휴대폰으로 인증 번호가 발송되었습니다."
                    android:textColor="#00ff00"
                    android:textSize="12dp"
                    android:visibility="invisible"
                    android:layout_marginStart="5dp"
                    android:layout_marginTop="5dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="20dp">

                </View>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RelativeLayout

                        android:layout_width="270dp"
                        android:layout_height="wrap_content"
                        android:paddingRight="10dp"
                        >

                        <EditText
                            android:id="@+id/emailCodeBox"
                            android:padding="12dp"
                            android:background="@drawable/selector_login"
                            android:hint="인증번호 입력"
                            android:textColorHint="@color/gray_02"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                        </EditText>

                        <TextView
                            android:id="@+id/timer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="03:00"
                            android:textSize="18dp"
                            android:textColor="#ff0000"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="20dp"
                            android:visibility="visible" />



                    </RelativeLayout>

                    <Button
                        android:id="@+id/phoneConfirmBtn"
                        android:layout_width="70dp"
                        android:layout_height="35dp"
                        android:text="확인"
                        android:background="@drawable/radius_purple_button"
                        android:textColor="@color/white"
                        android:layout_alignParentEnd="true"
                        android:layout_marginEnd="20dp"
                        android:layout_centerVertical="true"/>

                </RelativeLayout>

                <TextView
                    android:id="@+id/checkVery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text='@{signupViewModel.isPhoneVerified()?"인증되었습니다.":"인증번호가 올바르지 않습니다."}'
                    android:textColor="@{signupViewModel.isPhoneVerified()?@color/sub_green:@color/sub_red}"
                    android:textSize="12dp"
                    android:visibility="invisible"
                    android:layout_marginStart="5dp"
                    android:layout_marginTop="5dp"/>


            </LinearLayout>

        </LinearLayout>

        <Button
            android:background="@drawable/radius_purple_button"
            android:text="다음"
            android:textColor="@color/white"
            android:id="@+id/nextBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            >

        </Button>



    </androidx.constraintlayout.widget.ConstraintLayout>


</layout>
