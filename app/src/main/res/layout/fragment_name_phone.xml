<?xml version="1.0" encoding="utf-8"?>

<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".signup.fragment.NamePhoneFragment"
>

    <data>
        <variable
            name="signupViewModel"
            type="com.example.teacherforboss.signup.SignupViewModel" />

    </data>

    <LinearLayout
        android:background="@color/white"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        >

        <EditText
            android:id="@+id/nameBox"
            android:padding="12dp"
            android:background="@drawable/selector_login"
            android:hint="이름"
            android:textColorHint="@color/lightGrey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        </EditText>

        <View
            android:layout_width="match_parent"
            android:layout_height="20dp">

        </View>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/phoneNumBox"
                android:padding="12dp"
                android:background="@drawable/selector_login"
                android:hint="휴대폰 번호 ('-' 제외)"
                android:textColorHint="@color/lightGrey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            </EditText>

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/star"
                />

            <Button
                android:id="@+id/phoneVerifyBtn"
                android:layout_width="70dp"
                android:layout_height="35dp"
                android:text="인증하기"
                android:background="@drawable/radius_purple_button"
                android:textColor="@color/white"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="20dp"
                android:layout_centerVertical="true"/>

        </RelativeLayout>

        <TextView
            android:id="@+id/veryInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="해당 휴대폰으로 인증 번호가 발송되었습니다."
            android:textColor="@color/black"
            android:textSize="12dp"
            android:visibility="invisible"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="20dp">

        </View>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RelativeLayout

                android:layout_width="290dp"
                android:layout_height="wrap_content"
                android:paddingRight="10dp"
                >

                <EditText
                    android:id="@+id/emailCodeBox"
                    android:padding="12dp"
                    android:background="@drawable/selector_login"
                    android:hint="인증번호 입력"
                    android:textColorHint="@color/lightGrey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                </EditText>

                <TextView
                    android:id="@+id/timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="03:00"
                    android:textSize="18dp"
                    android:textColor="#ff0000"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="20dp"
                    android:visibility="visible" />



            </RelativeLayout>

            <Button
                android:id="@+id/phoneConfirmBtn"
                android:layout_width="70dp"
                android:layout_height="35dp"
                android:text="확인"
                android:background="@drawable/radius_purple_button"
                android:textColor="@color/white"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="20dp"
                android:layout_centerVertical="true"/>

        </LinearLayout>


        <TextView
            android:id="@+id/checkVery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text='@{signupViewModel.isPhoneVerified()?"인증되었습니다.":"인증번호가 올바르지 않습니다."}'
            android:textColor="@{signupViewModel.isPhoneVerified()?@color/lime:@color/red}"
            android:textSize="12dp"
            android:visibility="invisible"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"/>

    </LinearLayout>
</layout>
