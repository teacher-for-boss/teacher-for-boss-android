<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <data>
        <variable
            name="signupViewModel"
            type="com.example.teacherforboss.signup.SignupViewModel" />

    </data>

    <LinearLayout
        android:background="@color/white"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <ImageView
            android:id="@+id/back"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/back"
            android:layout_marginTop="5dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="50dp">

        </View>

        <LinearLayout
            android:id="@+id/loginTextBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >

            <TextView
                android:textStyle="bold"
                android:textSize="30dp"
                android:textColor="@color/black"
                android:text="회원가입"
                android:fontFamily="@font/lineseed_rg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            </TextView>


            <View
                android:layout_width="match_parent"
                android:layout_height="10dp">

            </View>

            <TextView
                android:text="혼자 고민하지 마세요"
                android:textColor="@color/black"
                android:textSize="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            </TextView>

            <TextView
                android:text="선생님의 노하우로 사장님을 성공 궤도로!"
                android:textColor="@color/black"
                android:textSize="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            </TextView>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="20dp">

        </View>

        <EditText
            android:id="@+id/pwBox"
            android:padding="12dp"
            android:background="@drawable/selector_login"
            android:hint="비밀번호"
            android:text="@={signupViewModel.livePw}"
            android:textColorHint="@color/lightGrey"
            android:inputType="textPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        </EditText>

        <LinearLayout
            android:weightSum="3"
            android:orientation="horizontal"
            android:layout_marginStart="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/pw_eng_include"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="영문포함 V"
                android:textColor="@{signupViewModel.eng_check?@color/main_purple:@color/grey}"
                android:textSize="12dp" />

            <TextView
                android:id="@+id/pw_num_include"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="숫자포함 V"
                android:textColor="@{signupViewModel.num_check?@color/main_purple:@color/grey}"
                android:textSize="12dp"
                android:layout_marginTop="5dp"
                android:layout_marginStart="10dp"/>

            <TextView
                android:id="@+id/pw_special_include"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="특수문자 V"
                android:textColor="@{signupViewModel.special_check?@color/main_purple:@color/grey}"
                android:textSize="12dp"
                android:layout_marginTop="5dp"
                android:layout_marginStart="10dp"/>

            <TextView
                android:id="@+id/pw_ch_limit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8-20자 이내 V"
                android:textColor="@{signupViewModel.length_check?@color/main_purple:@color/grey}"
                android:textSize="12dp"
                android:layout_marginTop="5dp"
                android:layout_marginStart="10dp"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="20dp">

        </View>

        <EditText
            android:id="@+id/pwReEnterBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/selector_login"
            android:hint="비밀번호 확인"
            android:inputType="textPassword"
            android:padding="12dp"
            android:text="@={signupViewModel.liveRePw}"
            android:textColorHint="@color/lightGrey">

        </EditText>

        <TextView
            android:id="@+id/pwInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{signupViewModel.rePw_check?@string/pwSame:@string/pwDifferent}"
            android:textColor="@{signupViewModel.rePw_check?@color/lime:@color/red}"
            android:textSize="12dp"
            android:visibility="invisible"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"/>


    </LinearLayout>


</layout>