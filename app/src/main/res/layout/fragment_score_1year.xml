<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100"
            android:textAppearance="@style/TextAppearance.TeacherForBoss.Body.Medium.12"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="55dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50"
            android:textAppearance="@style/TextAppearance.TeacherForBoss.Body.Medium.12"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="100dp"
            android:layout_marginStart="55dp"/>

        <TextView
            android:id="@+id/score_zero_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textAppearance="@style/TextAppearance.TeacherForBoss.Body.Medium.12"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="200dp"
            android:layout_marginStart="55dp"/>

        <ImageView
            android:id="@+id/score_ave_bar"
            android:layout_width="90dp"
            android:layout_height="122dp"
            android:src="@drawable/score_bar_1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/score_zero_tv"
            android:layout_marginStart="110dp" />

        <ImageView
            android:id="@+id/score_bar"
            android:layout_width="90dp"
            android:layout_height="150dp"
            android:src="@drawable/score_bar_2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/score_zero_tv"
            android:layout_marginStart="225dp" />

        <TextView
            android:id="@+id/score_ave_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="nn점"
            android:textAppearance="@style/TextAppearance.TeacherForBoss.Title.Bold.16"
            android:textColor="#7F7F7F"
            app:layout_constraintTop_toTopOf="@id/score_ave_bar"
            app:layout_constraintStart_toStartOf="@id/score_ave_bar"
            app:layout_constraintEnd_toEndOf="@id/score_ave_bar"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/score_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NN점"
            android:textAppearance="@style/TextAppearance.TeacherForBoss.Title.Bold.16"
            android:textColor="@color/white"
            app:layout_constraintTop_toTopOf="@id/score_bar"
            app:layout_constraintStart_toStartOf="@id/score_bar"
            app:layout_constraintEnd_toEndOf="@id/score_bar"
            android:layout_marginTop="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사장님 평균"
            android:textAppearance="@style/TextAppearance.TeacherForBoss.Body.Medium.14"
            app:layout_constraintTop_toBottomOf="@id/score_ave_bar"
            app:layout_constraintStart_toStartOf="@id/score_ave_bar"
            app:layout_constraintEnd_toEndOf="@id/score_ave_bar"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/boss_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="김빛나 사장님"
            android:textAppearance="@style/TextAppearance.TeacherForBoss.Body.Medium.14"
            app:layout_constraintTop_toBottomOf="@id/score_bar"
            app:layout_constraintStart_toStartOf="@id/score_bar"
            app:layout_constraintEnd_toEndOf="@id/score_bar"
            android:layout_marginTop="10dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="25dp"
            app:layout_constraintTop_toBottomOf="@id/boss_name"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>