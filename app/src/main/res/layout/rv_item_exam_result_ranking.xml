<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_margin="14dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white"
    >

        <LinearLayout
            android:weightSum="6"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:gravity="center_vertical|center_horizontal"
                android:textColor="@color/main_purple_00"
                android:layout_weight="1"
                android:textAlignment="center"
                android:textAppearance="@style/TextAppearance.TeacherForBoss.Title.Bold.16"
                android:id="@+id/ranking"
                android:layout_width="30dp"
                android:layout_height="match_parent">

            </TextView>

            <ImageView
                android:background="@drawable/radius_profile_img"
                android:layout_weight="1"
                android:src="@drawable/test_profile"
                android:layout_width="30dp"
                android:layout_height="match_parent">
            </ImageView>

            <TextView
                android:gravity="center_vertical|center_horizontal"
                android:layout_weight="2"
                android:textAppearance="@style/TextAppearance.TeacherForBoss.Body.Medium.16"
                android:id="@+id/name"
                android:layout_width="wrap_content"
                android:layout_height="match_parent">

            </TextView>

            <View
                android:layout_weight="0.2"
                android:layout_width="30dp"
                android:layout_height="match_parent">

            </View>

            <TextView
                android:gravity="center_vertical|center_horizontal"
                android:id="@+id/score"
                android:textColor="@color/main_purple_00"
                android:textAppearance="@style/TextAppearance.TeacherForBoss.Body.Medium.16"
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:layout_height="match_parent">

            </TextView>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>