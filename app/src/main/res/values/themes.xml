<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.TeacherForBoss" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/light_status</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Theme.TeacherForBoss" parent="Base.Theme.TeacherForBoss"/>
    
    <!-- Button -->
    <style name="Theme.TeacherForBoss.Button" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:backgroundTint">@color/selector_all_btn_background</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Theme.TeacherForBoss.Button.Survey" parent="Theme.TeacherForBoss.Button">
        <item name="android:height">@dimen/button_survey_height</item>
        <item name="cornerRadius">@dimen/button_survey_radius</item>
        <item name="android:textAppearance">@style/TextAppearance.TeacherForBoss.Body.Medium.16</item>
    </style>
</resources>